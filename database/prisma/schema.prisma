generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CountryMaster {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  name      String        @unique
  branches  Branch[]
  customers Customer[]
  states    StateMaster[]
  suppliers Supplier[]
}

model StateMaster {
  id        Int           @id @default(autoincrement())
  countryId Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  name      String
  branches  Branch[]
  cities    CityMaster[]
  customers Customer[]
  country   CountryMaster @relation(fields: [countryId], references: [id])
  suppliers Supplier[]

  @@unique([name, countryId])
}

model CityMaster {
  id         Int               @id @default(autoincrement())
  createdAt  DateTime          @default(now())
  stateId    Int
  updatedAt  DateTime          @updatedAt
  name       String
  areas      AreaMaster[]
  branches   Branch[]
  state      StateMaster       @relation(fields: [stateId], references: [id])
  customers  Customer[]
  suppliers  Supplier[]
  warehouses WarehouseMaster[]

  @@unique([name, stateId])
}

model AreaMaster {
  id         Int                @id @default(autoincrement())
  cityId     Int
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  name       String
  city       CityMaster         @relation(fields: [cityId], references: [id])
  branches   Branch[]
  customers  Customer[]
  suppliers  Supplier[]
  warehouses WarehouseMaster[]

  @@unique([name, cityId])
}

model WarehouseMaster {
  id        Int         @id @default(autoincrement())
  name      String
  address   String?
  areaId    Int?
  cityId    Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  area      AreaMaster? @relation(fields: [areaId], references: [id])
  city      CityMaster? @relation(fields: [cityId], references: [id])
}

model Branch {
  id        Int               @id @default(autoincrement())
  name      String
  address   String?
  areaId    Int?
  cityId    Int
  stateId   Int
  countryId Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  area      AreaMaster?       @relation(fields: [areaId], references: [id])
  city      CityMaster        @relation(fields: [cityId], references: [id])
  country   CountryMaster     @relation(fields: [countryId], references: [id])
  state     StateMaster       @relation(fields: [stateId], references: [id])
  purchases PurchaseVoucher[]
  sales     SalesVoucher[]
  users     User[]
}

model CategoryMaster {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  name      String    @unique
  products  Product[]
}

model UnitMaster {
  id        Int       @id @default(autoincrement())
  unitName  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  shortName String?
  products  Product[]
}

model Supplier {
  id        Int               @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  email     String?
  gstNo     String?
  areaId    Int?
  cityId    Int
  stateId   Int
  countryId Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  purchases PurchaseVoucher[]
  area      AreaMaster?       @relation(fields: [areaId], references: [id])
  city      CityMaster        @relation(fields: [cityId], references: [id])
  country   CountryMaster     @relation(fields: [countryId], references: [id])
  state     StateMaster       @relation(fields: [stateId], references: [id])
}

model Product {
  id            Int                   @id @default(autoincrement())
  name          String
  categoryId    Int
  unitId        Int
  purchasePrice Float
  sellingPrice  Float
  barcode       String?               @unique
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  category      CategoryMaster        @relation(fields: [categoryId], references: [id])
  unit          UnitMaster            @relation(fields: [unitId], references: [id])
  purchaseItems PurchaseVoucherItem[]
  salesItems    SalesVoucherItem[]
}

model Customer {
  id        Int            @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  gstNo     String?
  areaId    Int?
  cityId    Int
  stateId   Int
  countryId Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  area      AreaMaster?    @relation(fields: [areaId], references: [id])
  city      CityMaster     @relation(fields: [cityId], references: [id])
  country   CountryMaster  @relation(fields: [countryId], references: [id])
  state     StateMaster    @relation(fields: [stateId], references: [id])
  sales     SalesVoucher[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
  users       User[]
}

model User {
  id            Int               @id @default(autoincrement())
  name          String
  email         String            @unique
  password      String
  plainPassword String?
  branchId      Int
  permissions   String            @default("{}")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isActive    Boolean           @default(true)
  roleId      Int
  purchases PurchaseVoucher[]
  sales     SalesVoucher[]
  branch    Branch            @relation(fields: [branchId], references: [id])
  role      Role              @relation(fields: [roleId], references: [id])
}

model Module {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
}

model Permission {
  id        Int      @id @default(autoincrement())
  roleId    Int
  moduleId  Int
  canCreate Boolean  @default(false)
  canView   Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([roleId, moduleId])
}

model PaymentMethodMaster {
  id        Int               @id @default(autoincrement())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  name      String            @unique
  purchases PurchaseVoucher[]
  sales     SalesVoucher[]
}

model PurchaseVoucher {
  id              Int                   @id @default(autoincrement())
  voucherNo       String                @unique
  supplierId      Int
  branchId        Int
  paymentMethodId Int
  createdById     Int
  date            DateTime
  subTotal        Float                 @default(0)
  taxAmount       Float                 @default(0)
  discountAmount  Float                 @default(0)
  totalAmount     Float
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  branch          Branch                @relation(fields: [branchId], references: [id])
  createdBy       User                  @relation(fields: [createdById], references: [id])
  paymentMethod   PaymentMethodMaster   @relation(fields: [paymentMethodId], references: [id])
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  items           PurchaseVoucherItem[]
}

model PurchaseVoucherItem {
  id             Int             @id @default(autoincrement())
  voucherId      Int
  productId      Int
  qty            Float
  rate           Float
  subTotal       Float           @default(0)
  taxRate        Float           @default(0)
  taxAmount      Float           @default(0)
  discountAmount Float           @default(0)
  amount         Float
  product        Product         @relation(fields: [productId], references: [id])
  voucher        PurchaseVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

model SalesVoucher {
  id              Int                 @id @default(autoincrement())
  voucherNo       String              @unique
  customerId      Int
  branchId        Int
  paymentMethodId Int
  createdById     Int
  date            DateTime
  subTotal        Float               @default(0)
  taxAmount       Float               @default(0)
  discountAmount  Float               @default(0)
  totalAmount     Float
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  branch          Branch              @relation(fields: [branchId], references: [id])
  createdBy       User                @relation(fields: [createdById], references: [id])
  customer        Customer            @relation(fields: [customerId], references: [id])
  paymentMethod   PaymentMethodMaster @relation(fields: [paymentMethodId], references: [id])
  items           SalesVoucherItem[]
}

model SalesVoucherItem {
  id             Int          @id @default(autoincrement())
  voucherId      Int
  productId      Int
  qty            Float
  rate           Float
  subTotal       Float        @default(0)
  taxRate        Float        @default(0)
  taxAmount      Float        @default(0)
  discountAmount Float        @default(0)
  amount         Float
  product        Product      @relation(fields: [productId], references: [id])
  voucher        SalesVoucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}
