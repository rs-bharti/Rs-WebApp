// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////
// LOCATION MASTERS
////////////////////////////

model CountryMaster {
  id        Int            @id @default(autoincrement())
  name      String         @unique

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  states    StateMaster[]
  branches  Branch[]
  suppliers Supplier[]
  customers Customer[]
}

model StateMaster {
  id          Int            @id @default(autoincrement())
  name        String

  countryId   Int
  country     CountryMaster  @relation(fields: [countryId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  cities      CityMaster[]
  branches    Branch[]
  suppliers   Supplier[]
  customers   Customer[]

  @@unique([name, countryId])
}

model CityMaster {
  id          Int           @id @default(autoincrement())
  name        String

  stateId     Int
  state       StateMaster   @relation(fields: [stateId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  areas       AreaMaster[]
  suppliers   Supplier[]
  customers   Customer[]
  branches    Branch[]

  @@unique([name, stateId])
}

model AreaMaster {
  id        Int          @id @default(autoincrement())
  name      String

  cityId    Int
  city      CityMaster   @relation(fields: [cityId], references: [id])

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  branches  Branch[]
  suppliers Supplier[]
  customers Customer[]

  @@unique([name, cityId])
}

////////////////////////////
// BRANCH
////////////////////////////

model Branch {
  id          Int             @id @default(autoincrement())
  name        String
  address     String?

  areaId      Int?
  cityId      Int
  stateId     Int
  countryId   Int

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  area        AreaMaster?     @relation(fields: [areaId], references: [id])
  city        CityMaster      @relation(fields: [cityId], references: [id])
  state       StateMaster     @relation(fields: [stateId], references: [id])
  country     CountryMaster   @relation(fields: [countryId], references: [id])

  users       User[]
  purchases   PurchaseVoucher[]
  sales       SalesVoucher[]
  stocks      BranchStock[]
}

////////////////////////////
// PRODUCT MASTERS
////////////////////////////

model CategoryMaster {
  id        Int        @id @default(autoincrement())
  name      String     @unique

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  products  Product[]
}

model UnitMaster {
  id          Int        @id @default(autoincrement())
  unitName    String
  shortName   String?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products    Product[]
}

model Supplier {
  id          Int         @id @default(autoincrement())
  name        String
  address     String?
  phone       String?
  email       String?
  gstNo       String?

  areaId      Int?
  cityId      Int
  stateId     Int
  countryId   Int

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  area        AreaMaster?    @relation(fields: [areaId], references: [id])
  city        CityMaster     @relation(fields: [cityId], references: [id])
  state       StateMaster    @relation(fields: [stateId], references: [id])
  country     CountryMaster  @relation(fields: [countryId], references: [id])

  purchases   PurchaseVoucher[]
}

model Product {
  id              Int               @id @default(autoincrement())
  name            String

  categoryId      Int
  unitId          Int

  purchasePrice   Float
  sellingPrice    Float

  barcode         String?           @unique

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  category        CategoryMaster    @relation(fields: [categoryId], references: [id])
  unit            UnitMaster        @relation(fields: [unitId], references: [id])

  purchaseItems   PurchaseVoucherItem[]
  salesItems      SalesVoucherItem[]
  stocks          BranchStock[]
}

model BranchStock {
  id          Int      @id @default(autoincrement())
  branchId    Int
  productId   Int
  quantity    Float    @default(0)

  branch      Branch   @relation(fields: [branchId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@unique([branchId, productId])
}

////////////////////////////
// CUSTOMER
////////////////////////////

model Customer {
  id          Int          @id @default(autoincrement())
  name        String
  phone       String?
  email       String?
  address     String?
  gstNo       String?

  areaId      Int?
  cityId      Int
  stateId     Int
  countryId   Int

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  area        AreaMaster?    @relation(fields: [areaId], references: [id])
  city        CityMaster     @relation(fields: [cityId], references: [id])
  state       StateMaster    @relation(fields: [stateId], references: [id])
  country     CountryMaster  @relation(fields: [countryId], references: [id])

  sales       SalesVoucher[]
}

////////////////////////////
// USER + ROLE + PERMISSION
////////////////////////////

model Role {
  id            Int           @id @default(autoincrement())
  name          String        @unique

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  users         User[]
  permissions   Permission[]
}

model User {
  id             Int        @id @default(autoincrement())
  name           String
  email          String     @unique
  password       String

  roleId         Int
  branchId       Int

  isActive       Boolean    @default(true)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  role           Role       @relation(fields: [roleId], references: [id])
  branch         Branch     @relation(fields: [branchId], references: [id])

  purchases      PurchaseVoucher[]
  sales          SalesVoucher[]
}

model Module {
  id            Int            @id @default(autoincrement())
  name          String         @unique

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  permissions   Permission[]
}

model Permission {
  id            Int        @id @default(autoincrement())

  roleId        Int
  moduleId      Int

  canCreate     Boolean    @default(false)
  canView       Boolean    @default(false)
  canEdit       Boolean    @default(false)
  canDelete     Boolean    @default(false)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  role          Role       @relation(fields: [roleId], references: [id])
  module        Module     @relation(fields: [moduleId], references: [id])

  @@unique([roleId, moduleId])
}

////////////////////////////
// PAYMENT METHOD MASTER
////////////////////////////

model PaymentMethodMaster {
  id          Int                 @id @default(autoincrement())
  name        String              @unique

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  purchases   PurchaseVoucher[]
  sales       SalesVoucher[]
}

////////////////////////////
// PURCHASE VOUCHER
////////////////////////////

model PurchaseVoucher {
  id                Int                    @id @default(autoincrement())
  voucherNo         String                 @unique

  supplierId        Int
  branchId          Int
  paymentMethodId   Int
  createdById       Int

  date              DateTime
  subTotal          Float                  @default(0)
  taxAmount         Float                  @default(0)
  discountAmount    Float                  @default(0)
  totalAmount       Float

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  supplier          Supplier              @relation(fields: [supplierId], references: [id])
  branch            Branch                @relation(fields: [branchId], references: [id])
  paymentMethod     PaymentMethodMaster   @relation(fields: [paymentMethodId], references: [id])
  createdBy         User                  @relation(fields: [createdById], references: [id])

  items             PurchaseVoucherItem[]
}

model PurchaseVoucherItem {
  id            Int                 @id @default(autoincrement())

  voucherId     Int
  productId     Int

  qty           Float
  rate          Float
  subTotal      Float               @default(0)
  taxRate       Float               @default(0)
  taxAmount     Float               @default(0)
  discountAmount Float              @default(0)
  amount        Float

  voucher       PurchaseVoucher     @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  product       Product             @relation(fields: [productId], references: [id])
}

////////////////////////////
// SALES VOUCHER
////////////////////////////

model SalesVoucher {
  id                Int                    @id @default(autoincrement())
  voucherNo         String                 @unique

  customerId        Int
  branchId          Int
  paymentMethodId   Int
  createdById       Int

  date              DateTime
  subTotal          Float                  @default(0)
  taxAmount         Float                  @default(0)
  discountAmount    Float                  @default(0)
  totalAmount       Float

  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  customer          Customer              @relation(fields: [customerId], references: [id])
  branch            Branch                @relation(fields: [branchId], references: [id])
  paymentMethod     PaymentMethodMaster   @relation(fields: [paymentMethodId], references: [id])
  createdBy         User                  @relation(fields: [createdById], references: [id])

  items             SalesVoucherItem[]
}

model SalesVoucherItem {
  id            Int               @id @default(autoincrement())

  voucherId     Int
  productId     Int

  qty           Float
  rate          Float
  subTotal      Float             @default(0)
  taxRate       Float             @default(0)
  taxAmount     Float             @default(0)
  discountAmount Float            @default(0)
  amount        Float

  voucher       SalesVoucher      @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  product       Product           @relation(fields: [productId], references: [id])
}