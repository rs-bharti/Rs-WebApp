generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String
}

model CustomerMaster {
  id      Int    @id @default(autoincrement())
  name    String
  address String @unique
  city    String
  state   String
  country String
}

model AreaMaster {
  id       Int    @id @default(autoincrement())
  areaName String
  city     String
}

model CityMaster {
  id        Int    @id @default(autoincrement())
  cityName  String
  stateName String
}

model StateMaster {
  id          Int    @id @default(autoincrement())
  stateName   String
  countryName String
}

model CountryMaster {
  id       Int    @id @default(autoincrement())
  countryName String
}

model PaymentMethodMaster {
  id         Int    @id @default(autoincrement())
  methodName String
}

model SupplierMaster {
  id           Int    @id @default(autoincrement())
  supplierName String
  address      String
  city         String
  state        String
  country      String
}

model ProductMaster {
  id          Int    @id @default(autoincrement())
  productName String
  category    String
  supplier    String
  unit        String
  lowestPrice String
}

model CategoryMaster {
  id           Int    @id @default(autoincrement())
  categoryName String
}

model UnitMaster {
  id       Int    @id @default(autoincrement())
  unitName String
}

model BranchMaster {
  id          Int    @id @default(autoincrement())
  branchName  String
  stateName   String
  countryName String
}
